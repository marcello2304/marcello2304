# ENV Template für Server 2 (Ollama + LiveKit)

# ═══════════════════════════════════════════════
# ALLGEMEIN
# ═══════════════════════════════════════════════
DOMAIN=deine-domain.de

# ═══════════════════════════════════════════════
# OLLAMA
# ═══════════════════════════════════════════════
# Token der in Nginx als Bearer-Token erwartet wird
OLLAMA_BEARER_TOKEN=SICHERES_OLLAMA_API_TOKEN_HIER

# ═══════════════════════════════════════════════
# LIVEKIT
# ═══════════════════════════════════════════════
# Generieren: openssl rand -hex 16
LIVEKIT_API_KEY=LIVEKIT_API_KEY_HIER
# Generieren: openssl rand -hex 32
LIVEKIT_API_SECRET=LIVEKIT_API_SECRET_HIER

# ═══════════════════════════════════════════════
# LIVEKIT AGENT (Voice Bot)
# ═══════════════════════════════════════════════
# STT: Deepgram (empfohlen für DE) oder OpenAI Whisper
DEEPGRAM_API_KEY=
# TTS: OpenAI (optional, oder lokales Piper/Kokoro)
OPENAI_API_KEY=

# Server 1 RAG Webhook (für Voice Agent → RAG)
RAG_WEBHOOK_URL=https://n8n.deine-domain.de/webhook/rag-query
RAG_WEBHOOK_SECRET=SHARED_SECRET_ZWISCHEN_SERVER1_UND_SERVER2
