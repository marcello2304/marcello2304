# ENV Template für Server 1 (Coolify)
# NICHT committen mit echten Werten!
# Kopieren als .env und ausfüllen:
#   cp server1.env.example .env
#   vim .env

# ═══════════════════════════════════════════════
# ALLGEMEIN
# ═══════════════════════════════════════════════
DOMAIN=deine-domain.de
ADMIN_IP=DEINE.ADMIN.IP.ADRESSE
ACME_EMAIL=admin@deine-domain.de
TZ=Europe/Berlin

# ═══════════════════════════════════════════════
# POSTGRESQL
# ═══════════════════════════════════════════════
POSTGRES_PASSWORD=SICHERES_POSTGRES_PASSWORT_HIER_AENDERN
POSTGRES_USER=postgres
POSTGRES_DB=app_db

# ═══════════════════════════════════════════════
# N8N
# ═══════════════════════════════════════════════
# Generieren: openssl rand -hex 32
N8N_ENCRYPTION_KEY=HIER_32_ZEICHEN_ZUFALLSSTRING
N8N_ADMIN_USER=admin
N8N_ADMIN_PASSWORD=SICHERES_N8N_ADMIN_PASSWORT

# ═══════════════════════════════════════════════
# TYPEBOT
# ═══════════════════════════════════════════════
# Generieren: openssl rand -hex 32
TYPEBOT_SECRET=HIER_32_ZEICHEN_ZUFALLSSTRING_FUER_TYPEBOT

# ═══════════════════════════════════════════════
# HETZNER OBJECT STORAGE (S3-kompatibel)
# ═══════════════════════════════════════════════
S3_ACCESS_KEY=HETZNER_S3_ACCESS_KEY_ID_HIER
S3_SECRET_KEY=HETZNER_S3_SECRET_ACCESS_KEY_HIER
S3_BUCKET=rag-platform-prod
S3_REGION=eu-central-003
# Endpoint: fsn1 = Falkenstein, nbg1 = Nürnberg
S3_ENDPOINT=https://fsn1.your-objectstorage.com

# Backup-Bucket (separater Bucket für Backups):
S3_BACKUP_BUCKET=rag-backups
S3_BACKUP_ENDPOINT=https://fsn1.your-objectstorage.com

# ═══════════════════════════════════════════════
# OLLAMA (Server 2)
# ═══════════════════════════════════════════════
OLLAMA_BASE_URL=https://ollama.deine-domain.de
# Bearer Token — muss auf Server 2 in Nginx konfiguriert sein:
OLLAMA_API_KEY=SICHERES_OLLAMA_API_TOKEN_HIER

# ═══════════════════════════════════════════════
# SMTP (für Typebot E-Mail Auth)
# ═══════════════════════════════════════════════
SMTP_HOST=smtp.provider.de
SMTP_PORT=587
SMTP_USER=noreply@deine-domain.de
SMTP_PASSWORD=SMTP_PASSWORT_HIER
SMTP_FROM=noreply@deine-domain.de

# ═══════════════════════════════════════════════
# BACKUP
# ═══════════════════════════════════════════════
BACKUP_DIR=/opt/backups/postgres
POSTGRES_CONTAINER=postgres-rag
RETENTION_DAYS=30
