# Admin UI Konfiguration
# Diese Datei NICHT in Git committen (.env)

DATABASE_URL=postgresql://appuser:DEIN_PASSWORT@postgres:5432/appdb
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_BUCKET=typebot-assets
S3_ACCESS_KEY=DEIN_S3_KEY
S3_SECRET_KEY=DEIN_S3_SECRET
S3_REGION=nbg1

N8N_URL=https://workflows.DEINE_DOMAIN.de
OLLAMA_URL=http://10.0.0.3:11434
EMBED_MODEL=qwen3-embedding:0.6b

# Mindestens 32 Zeichen, nur du kennst ihn
ADMIN_API_KEY=aendere-diesen-key-sofort-auf-etwas-sicheres

# Super-Admin E-Mail (hat Zugriff auf ALLE Tenants)
SUPER_ADMIN_EMAIL=eppler@eppcom.de

# Embedding-Dimensionen (768 für nomic-embed-text)
EMBED_DIM=768

# Chunking-Einstellungen
CHUNK_SIZE=800
CHUNK_OVERLAP=200

# Max. Media-Upload-Groesse (Bytes, Standard: 100 MB)
MAX_MEDIA_SIZE=104857600

# ═══════════════════════════════════════════════════════════════════════════════
# LIVEKIT Voice Bot Konfiguration
# ═══════════════════════════════════════════════════════════════════════════════
# LiveKit API Key und Secret (von Server 2)
LIVEKIT_API_KEY=your-livekit-api-key-here
LIVEKIT_API_SECRET=your-livekit-api-secret-here
