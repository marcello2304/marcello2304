{
  "version": "6",
  "name": "EPPCOM Assistent",
  "icon": {
    "type": "emoji",
    "emoji": "🤖"
  },
  "theme": {
    "general": {
      "font": "Inter",
      "background": { "type": "Color", "content": "#FFFFFF" }
    },
    "chat": {
      "hostAvatar": { "isEnabled": true },
      "guestBubbles": {
        "backgroundColor": "#2563EB",
        "color": "#FFFFFF",
        "borderRadius": 12
      },
      "hostBubbles": {
        "backgroundColor": "#F1F5F9",
        "color": "#1E293B",
        "borderRadius": 12
      },
      "inputs": {
        "backgroundColor": "#FFFFFF",
        "color": "#1E293B",
        "placeholderColor": "#94A3B8"
      },
      "buttons": {
        "backgroundColor": "#2563EB",
        "color": "#FFFFFF"
      }
    }
  },
  "settings": {
    "general": {
      "isBrandingEnabled": false,
      "isInputPrefillEnabled": true,
      "isHideQueryParamsEnabled": true,
      "rememberUser": {
        "isEnabled": false
      }
    },
    "typingEmulation": {
      "enabled": true,
      "speed": 400,
      "maxDelay": 1.5
    }
  },
  "groups": [
    {
      "id": "grp-init",
      "title": "Init — Variablen setzen",
      "blocks": [
        {
          "id": "blk-set-vars",
          "type": "script",
          "content": {
            "code": "// Tenant & API-Key setzen (wird über prefilledVariables überschrieben wenn vom Embed übergeben)\nif (!getVariable('tenantId') || getVariable('tenantId') === '') {\n  setVariable('tenantId', 'a0000000-0000-0000-0000-000000000001');\n}\nif (!getVariable('apiKey') || getVariable('apiKey') === '') {\n  setVariable('apiKey', 'DEIN_API_KEY_HIER');\n}\n// Session-ID generieren\nconst id = 'web_' + Date.now() + '_' + Math.random().toString(36).substr(2, 8);\nsetVariable('sessionId', id);"
          }
        }
      ],
      "edges": [{ "to": { "groupId": "grp-welcome" } }]
    },
    {
      "id": "grp-welcome",
      "title": "Begrüßung",
      "blocks": [
        {
          "id": "blk-welcome",
          "type": "text",
          "content": {
            "richText": [
              {
                "type": "p",
                "children": [{ "text": "👋 Hallo! Wie kann ich Ihnen helfen?" }]
              },
              {
                "type": "p",
                "children": [{ "text": "Ich beantworte Fragen direkt aus unserer Wissensdatenbank — schnell, präzise und DSGVO-konform." }]
              }
            ]
          }
        },
        {
          "id": "blk-ask-question",
          "type": "text input",
          "options": {
            "labels": {
              "placeholder": "Ihre Frage eingeben...",
              "button": "Absenden"
            },
            "isLong": false,
            "variableId": "v-user-question"
          }
        }
      ],
      "edges": [{ "to": { "groupId": "grp-rag-call" } }]
    },
    {
      "id": "grp-rag-call",
      "title": "RAG-Abfrage",
      "blocks": [
        {
          "id": "blk-thinking",
          "type": "text",
          "content": {
            "richText": [
              { "type": "p", "children": [{ "text": "⏳ Ich suche in der Wissensdatenbank..." }] }
            ]
          }
        },
        {
          "id": "blk-http",
          "type": "http request",
          "options": {
            "url": "https://workflows.eppcom.de/webhook/rag-chat",
            "method": "POST",
            "headers": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" },
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "body": "{\"query\": \"{{userQuestion}}\", \"session_id\": \"{{sessionId}}\"}",
            "responseVariableMapping": [
              { "bodyPath": "answer", "variableId": "v-rag-answer" },
              { "bodyPath": "chunks_used", "variableId": "v-chunks-used" }
            ],
            "isAdvancedConfig": false,
            "timeout": 30000
          }
        }
      ],
      "edges": [
        {
          "id": "edge-to-answer",
          "from": { "blockId": "blk-http" },
          "to": { "groupId": "grp-show-answer" }
        }
      ]
    },
    {
      "id": "grp-show-answer",
      "title": "Antwort anzeigen",
      "blocks": [
        {
          "id": "blk-answer",
          "type": "text",
          "content": {
            "richText": [
              { "type": "p", "children": [{ "text": "{{ragAnswer}}" }] }
            ]
          }
        },
        {
          "id": "blk-followup-prompt",
          "type": "text",
          "content": {
            "richText": [
              { "type": "p", "children": [{ "text": "Haben Sie noch eine Frage?" }] }
            ]
          }
        },
        {
          "id": "blk-followup-input",
          "type": "text input",
          "options": {
            "labels": {
              "placeholder": "Nächste Frage...",
              "button": "Absenden"
            },
            "isLong": false,
            "variableId": "v-user-question"
          }
        }
      ],
      "edges": [{ "to": { "groupId": "grp-rag-call" } }]
    }
  ],
  "variables": [
    {
      "id": "v-tenant-id",
      "name": "tenantId",
      "value": "a0000000-0000-0000-0000-000000000001"
    },
    {
      "id": "v-api-key",
      "name": "apiKey",
      "value": "DEIN_API_KEY_HIER"
    },
    {
      "id": "v-session-id",
      "name": "sessionId",
      "value": ""
    },
    {
      "id": "v-user-question",
      "name": "userQuestion",
      "value": ""
    },
    {
      "id": "v-rag-answer",
      "name": "ragAnswer",
      "value": ""
    },
    {
      "id": "v-chunks-used",
      "name": "chunksUsed",
      "value": ""
    }
  ],
  "edges": []
}
