          "type": "Code",
          "options": {
            "name": "RAG Abfrage",
            "content": "try {\n  var frage = '{{frage}}';\n  var xhr = new XMLHttpRequest();\n  xhr.open('POST', 'https://appdb.eppcom.de/api/public/chat', false);\n  xhr.setRequestHeader('Content-Type', 'application/json');\n  xhr.setRequestHeader('X-Tenant-ID', 'a0000000-0000-0000-0000-000000000001');\n  xhr.setRequestHeader('X-API-Key', 'c9c2f723d67806e57d5a058f8320aac6491295a4cfbfa716247cfc70d9e739de');\n  xhr.timeout = 120000;\n  xhr.send(JSON.stringify({query: frage, session_id: 'tb_' + Date.now()}));\n  if (xhr.status === 200) {\n    var data = JSON.parse(xhr.responseText);\n    setVariable('ai_antwort', data.answer);\n  } else {\n    setVariable('ai_antwort', 'Fehler bei der Verarbeitung (Status: ' + xhr.status + ')');\n  }\n} catch(e) {\n  setVariable('ai_antwort', 'Technischer Fehler: ' + e.message);\n}",
            "shouldExecuteInParentContext": false
          }
        }
      ],
